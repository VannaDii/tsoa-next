{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "packages",
  "entryPoints": [
    "packages/*"
  ],
  "name": "tsoa-next",
  "includeVersion": true,
  "plugin": [
    "typedoc-plugin-markdown",
    "typedoc-vitepress-theme"
  ],
  "useCodeBlocks": true,
  "out": "./site/guide-docs/reference",
  "docsRoot": "./site/guide-docs",
  "hostedBaseUrl": "https://tsoa-next.dev/reference/",
  "packageOptions": {
    "validation": {
      "notExported": false
    }
  },
  "validation": {
    "notExported": false
  }
}
